# ──────────────────────────────────────────────
# LLMGov .gitignore
# ──────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment & secrets
.env
.env.*
!.env.example

# Docker
docker/volumes/

# Testing & coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Logs
*.log
logs/

# OS
*.bak
*.tmp

# Temporary files & Scratchpads
docs_extracted*.txt
spec.txt
scratch*.py
tests/scratch*.py

# Terraform
*.tfstate
*.tfstate.*
.terraform/
*.pem

# Personal & Internal Audit Files (Local Only)
docs/resume_bullets.md
docs/mock_interview.md
updates.md
docs/updates.md

