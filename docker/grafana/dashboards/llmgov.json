          "rawSql": "SELECT provider, quantile(0.50)(total_duration_ms) AS p50_ms, quantile(0.95)(total_duration_ms) AS p95_ms, quantile(0.99)(total_duration_ms) AS p99_ms FROM default.llm_metrics WHERE timestamp > now() - INTERVAL 1 DAY GROUP BY provider",
