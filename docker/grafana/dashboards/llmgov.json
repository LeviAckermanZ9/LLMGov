          "rawSql": "SELECT app_id, model_used, prompt_version, count() AS total_requests, sum(calculated_cost) AS total_cost FROM default.llm_metrics WHERE timestamp > now() - INTERVAL 30 DAY GROUP BY app_id, model_used, prompt_version ORDER BY total_requests DESC",
